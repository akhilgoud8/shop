# ShopZen backend configuration
# Do NOT commit real secrets to version control.

# Flask
FLASK_APP=app.py
FLASK_DEBUG=0
PORT=5000

# Security
SECRET_KEY=change-this-to-a-long-random-string-in-production
# Set to 1 once you have HTTPS in front of the backend (via ALB/Nginx + cert)
SESSION_COOKIE_SECURE=0

# Database (RDS MySQL / MariaDB)
DB_HOST=database-1.cl4suwy60mbo.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=Cloud123
DB_NAME=shopzen

# CORS - only needed if the frontend is NOT reverse-proxied onto the same
# origin as this API (see nginx/shopzen.conf, which avoids needing this).
CORS_ORIGINS=*

# Mail (used for login notifications + order confirmation emails)
# For Gmail: use an App Password, not your normal account password
# (Google Account -> Security -> App Passwords). For production, consider
# Amazon SES instead of Gmail SMTP.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=s31869965@gmail.com
MAIL_PASSWORD=ivyp ukuz xemp qkiq
MAIL_FROM_NAME=ShopZen
